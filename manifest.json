{
  "manifest_version": 3,
  "name": "翻译助手 MVP",
  "description": "一个基于 OpenAI 兼容接口的最小可运行 Chrome 翻译插件。",
  "version": "0.1.0",
  "action": {
    "default_title": "打开翻译助手",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "commands": {
    "trigger-selection-translate": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "翻译当前选中的文本"
    }
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
